# AdMob App ID — from AdMob dashboard > Apps > your app > App ID (format: ca-app-pub-...~...)
# Used at build time (expo prebuild) to configure the native AdMob SDK
ADMOB_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX

# AdMob banner ad unit ID — from AdMob dashboard > Ad units (format: ca-app-pub-.../...)
# Used at runtime to load the banner ad
EXPO_PUBLIC_ADMOB_BANNER_ID=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY

# RevenueCat Google API key — from RevenueCat dashboard > App Settings > API Keys > Google Play
# Used at runtime to verify in-app purchases
EXPO_PUBLIC_REVENUECAT_GOOGLE_API_KEY=goog_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
